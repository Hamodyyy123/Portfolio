<script>
document.getElementById('yr').textContent = new Date().getFullYear();

const prog = document.getElementById('prog');
window.addEventListener('scroll', () => {
  prog.style.width = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100) + '%';
}, { passive: true });

const hdr = document.getElementById('hdr');
window.addEventListener('scroll', () => {
  hdr.style.borderBottomColor = window.scrollY > 30 ? 'rgba(255,255,255,.1)' : 'var(--border)';
}, { passive: true });

const ham = document.getElementById('ham');
const mob = document.getElementById('mobnav');
ham.addEventListener('click', () => {
  const o = mob.classList.toggle('open');
  ham.setAttribute('aria-expanded', o);
});
mob.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  mob.classList.remove('open'); ham.setAttribute('aria-expanded', 'false');
}));

const words = ['Developer', 'Shopify Expert', 'Problem Solver'];
let wi = 0, ci = 0, del = false;
const typedEl = document.getElementById('typed');
function type() {
  const w = words[wi];
  typedEl.textContent = del ? w.slice(0, ci--) : w.slice(0, ci++);
  if (!del && ci > w.length)  { del = true; setTimeout(type, 1500); return; }
  if (del  && ci < 0)          { del = false; wi = (wi + 1) % words.length; ci = 0; setTimeout(type, 400); return; }
  setTimeout(type, del ? 48 : 85);
}
type();

const rvs = document.querySelectorAll('.rv');
const obs = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      e.target.style.transitionDelay = (i % 4) * 0.08 + 's';
      e.target.classList.add('on');
      obs.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
rvs.forEach(el => obs.observe(el));

const ps = document.getElementById('portScroll');
let down = false, startX, sL;
ps.addEventListener('mousedown',  e => { down = true; startX = e.pageX - ps.offsetLeft; sL = ps.scrollLeft; });
ps.addEventListener('mouseleave', () => { down = false; });
ps.addEventListener('mouseup',    () => { down = false; });
ps.addEventListener('mousemove',  e => {
  if (!down) return; e.preventDefault();
  ps.scrollLeft = sL - (e.pageX - ps.offsetLeft - startX) * 1.2;
});

document.querySelectorAll('.pcard').forEach(card => {
  const prev = card.querySelector('.pcard-prev');
  prev.addEventListener('click', () => openCS(card.dataset.proj));
  prev.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openCS(card.dataset.proj); } });
});

const dv = { frag: 987, louve: 2341, rxn: 1872, nutriboost: 3104, elnon: 1567 };
Object.keys(dv).forEach(k => {
  const sk = 'vc_' + k;
  if (!localStorage.getItem(sk)) localStorage.setItem(sk, dv[k]);
  const el = document.getElementById('v-' + k);
  if (el) el.textContent = parseInt(localStorage.getItem(sk)).toLocaleString();
});

const cs = {
  frag: { title: 'Frag. — Eau de Parfum', url: 'https://myfrag.lovable.app/',
    problem:  ['A luxury perfume brand needed a cinematic digital presence that matched their ultra-premium positioning — think editorial magazine, not standard e-commerce.'],
    solution: ['Dark editorial Shopify storefront built on Lovable with custom gold-on-black design system, immersive hero section with liquid-splash photography.', 'Scent storytelling product pages, ASP.NET-backed custom fragrance quiz, and smooth cinematic scroll experience.'],
    outcome:  ['Brand immediately communicates luxury positioning to first-time visitors.', 'Detailed revenue metrics confidential per client agreement.'] },
  louve: { title: 'Louvé Store', url: 'https://xn--louv-bsa.store',
    problem:  ['Luxury fashion brand needed an editorial online presence that matched their premium positioning while converting browsers into buyers.'],
    solution: ['Custom Shopify theme in Liquid with editorial layout, smooth section transitions, and trust-building elements throughout.', 'Structured product pages with high-quality imagery, social proof, and a simplified single-page checkout.'],
    outcome:  ['Improved page engagement and dwell time post-launch.', 'Detailed revenue metrics confidential per client agreement.'] },
  rxn: { title: 'RXN Brand', url: 'https://epaazj-iv.myshopify.com/',
    problem:  ['Athletic apparel brand needed a bold, dark storefront that matched their aggressive brand identity while being fast on mobile.'],
    solution: ['Mobile-first Shopify theme with full-bleed editorial photography, fast-loading product cards, and streamlined size selection checkout.', 'WebP images and lazy loading for sub-2s load times on 4G.'],
    outcome:  ['Mobile bounce rate reduced significantly after launch.', 'Store in active growth phase — detailed metrics not yet available.'] },
  nutriboost: { title: 'NutriBoost Egypt', url: 'https://nutriboosteg.com/',
    problem:  ['Egyptian supplement brand needed streamlined bundle purchasing and integration with local logistics and payment providers.'],
    solution: ['Custom Shopify bundle app with dynamic pricing and upsell logic.', 'Integrated local courier and payment APIs not natively supported by Shopify.'],
    outcome:  ['Average order value increased via product bundle upsells.', 'Detailed revenue metrics confidential per client agreement.'] },
  elnon: { title: 'El Non Store', url: 'https://elnonstore.lovable.app/',
    problem:  ['Brand wanted a visually cinematic experience beyond standard Shopify — one that matched their aspirational brand positioning.'],
    solution: ['React frontend via Lovable connected to Shopify Storefront API for real-time product data and cart management.', 'Code-split and lazy-loaded for perfect Core Web Vitals on both mobile and desktop.'],
    outcome:  ['Lighthouse scores in the 95+ range on desktop.', 'Client metrics are private — outcome data unavailable.'] }
};
function openCS(id) {
  const d = cs[id]; if (!d) return;
  document.getElementById('mttl').textContent = d.title;
  document.getElementById('mbody').innerHTML = `
    <div class="ms"><div class="mst">Problem</div><div class="mbs">${d.problem.map(p=>`<div class="mb">${p}</div>`).join('')}</div></div>
    <div class="ms"><div class="mst">Solution</div><div class="mbs">${d.solution.map(s=>`<div class="mb">${s}</div>`).join('')}</div></div>
    <div class="ms"><div class="mst">Outcome</div><div class="mbs">${d.outcome.map(o=>`<div class="mb">${o}</div>`).join('')}</div></div>
    <a href="${d.url}" target="_blank" rel="noopener" class="btn-p" style="margin-top:8px;display:inline-flex">Visit Live Site
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>`;
  const mbd = document.getElementById('mbd');
  mbd.classList.add('open'); mbd.setAttribute('aria-hidden', 'false');
  document.getElementById('mcls').focus();
  document.body.style.overflow = 'hidden';
  const sk = 'vc_' + id;
  const n = (parseInt(localStorage.getItem(sk)) || 0) + 1;
  localStorage.setItem(sk, n);
  const ve = document.getElementById('v-' + id); if (ve) ve.textContent = n.toLocaleString();
}
function closeModal() {
  const mbd = document.getElementById('mbd');
  mbd.classList.remove('open'); mbd.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}
document.getElementById('mcls').addEventListener('click', closeModal);
document.getElementById('mbd').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

document.getElementById('ctForm').addEventListener('submit', function(e) {
  e.preventDefault();
  if (!document.getElementById('nm').value.trim() ||
      !document.getElementById('em').value.trim() ||
      !document.getElementById('br').value.trim()) {
    alert('Please fill in all required fields.'); return;
  }
  this.style.display = 'none';
  document.getElementById('formOk').classList.add('show');
});

