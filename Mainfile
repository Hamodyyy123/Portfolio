document.getElementById('ck-ok').addEventListener('click', () => { localStorage.setItem('cc','ok'); ck.classList.add('hidden'); initGA(); });
document.getElementById('ck-no').addEventListener('click', () => { localStorage.setItem('cc','no'); ck.classList.add('hidden'); });
function initGA() {
  const s = document.createElement('script'); s.async = true;
  s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX';
