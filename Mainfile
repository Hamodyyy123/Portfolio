<style>
:root {
  --bg:        #080B12;
  --bg-card:   #0E1118;
  --bg-raised: #131720;
  --border:    rgba(255,255,255,.07);
  --border-hi: rgba(255,255,255,.13);
  --text:      #EEF0F8;
  --muted:     rgba(238,240,248,.52);
  --faint:     rgba(238,240,248,.28);
  --accent:    #4FACDE;
  --accent2:   #2D8FB8;
  --accent-g:  linear-gradient(135deg,#4FACDE,#A78BFA);
  --green:     #34D399;
  --gold:      #FBBF24;
  --r:         12px;
  --r2:        20px;
  --f-head:    'Syne',sans-serif;
  --f-body:    'Epilogue',sans-serif;
  --ease:      cubic-bezier(.4,0,.2,1);
  --ease-out:  cubic-bezier(0,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--f-body);background:var(--bg);color:var(--text);line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
ul{list-style:none}
body::before{content:'';position:fixed;inset:0;z-index:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.018;pointer-events:none}
#prog{position:fixed;top:0;left:0;height:2px;z-index:1000;background:var(--accent-g);width:0%;box-shadow:0 0 10px rgba(79,172,222,.4)}
.skip{position:absolute;top:-60px;left:16px;background:var(--accent);color:#000;padding:10px 20px;border-radius:0 0 10px 10px;font-weight:700;z-index:9999}
.skip:focus{top:0}
.wrap{max-width:1140px;margin:0 auto;padding:0 36px}
section{padding:112px 0;position:relative;z-index:1}

/* HEADER */
header{position:fixed;top:0;left:0;right:0;z-index:500;background:rgba(8,11,18,.82);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
nav{display:flex;align-items:center;justify-content:space-between;height:66px;max-width:1140px;margin:0 auto;padding:0 36px}
.logo{font-family:var(--f-head);font-size:1.1rem;font-weight:800;letter-spacing:-.02em;color:var(--text)}
.logo span{color:var(--accent)}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:.8rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);transition:color .22s}
.nav-links a:hover,.nav-links a:focus{color:var(--text)}
.nav-cta{background:transparent!important;border:1.5px solid var(--accent)!important;color:var(--accent)!important;padding:8px 22px;border-radius:8px;font-size:.78rem!important;transition:background .22s,box-shadow .22s!important}
.nav-cta:hover{background:rgba(79,172,222,.1)!important;box-shadow:0 0 18px rgba(79,172,222,.2)!important;color:var(--accent)!important}
.ham{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:8px;cursor:pointer}
.ham span{width:22px;height:1.5px;background:var(--text);display:block;transition:.28s var(--ease);transform-origin:center}
.ham[aria-expanded="true"] span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.ham[aria-expanded="true"] span:nth-child(2){opacity:0}
.ham[aria-expanded="true"] span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}
.mob-nav{display:none;flex-direction:column;background:rgba(8,11,18,.97);border-top:1px solid var(--border);padding:12px 0 20px}
.mob-nav.open{display:flex}
.mob-nav a{padding:13px 36px;font-size:.9rem;color:var(--muted);font-weight:500;transition:color .2s}
.mob-nav a:hover{color:var(--accent)}

/* SECTION LABELS */
.stag{display:inline-flex;align-items:center;gap:10px;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:var(--accent);margin-bottom:16px}
.stag::before{content:'';width:18px;height:1.5px;background:var(--accent);display:block}
.sh{font-family:var(--f-head);font-size:clamp(2rem,4vw,3.4rem);font-weight:800;line-height:1.1;letter-spacing:-.03em;margin-bottom:16px}
.sh em{font-style:normal;background:var(--accent-g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ssub{font-size:1.05rem;color:var(--muted);max-width:500px;line-height:1.85}
.sec-hd{margin-bottom:60px}
.sec-hd.c{text-align:center}
.sec-hd.c .ssub{margin:0 auto}

/* BUTTONS */
.btn-p{display:inline-flex;align-items:center;gap:10px;background:var(--accent);color:#000;padding:14px 30px;border-radius:10px;font-size:.9rem;font-weight:700;letter-spacing:.02em;border:none;box-shadow:0 4px 20px rgba(79,172,222,.28);transition:transform .25s var(--ease),box-shadow .25s,background .2s}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(79,172,222,.38);background:#69BADF}
.btn-s{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--text);padding:14px 30px;border-radius:10px;font-size:.9rem;font-weight:600;border:1.5px solid var(--border-hi);transition:border-color .25s,background .25s,transform .25s var(--ease)}
.btn-s:hover{border-color:var(--accent);background:rgba(79,172,222,.06);transform:translateY(-2px)}

/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;padding:130px 0 100px;overflow:hidden}
.hero-glow{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0}
.glow-a{width:500px;height:500px;top:-10%;right:0;background:rgba(79,172,222,.07)}
.glow-b{width:340px;height:340px;bottom:0;left:-5%;background:rgba(167,139,250,.06)}
.hero-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:72px;align-items:center;position:relative;z-index:1}
.h-eye{display:inline-flex;align-items:center;gap:9px;font-size:.74rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);padding:7px 16px;border-radius:100px;background:rgba(79,172,222,.08);border:1px solid rgba(79,172,222,.2);margin-bottom:28px}
.eye-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px rgba(52,211,153,.6)}
.h-head{font-family:var(--f-head);font-size:clamp(2.8rem,6vw,4.8rem);font-weight:800;line-height:1.04;letter-spacing:-.04em;margin-bottom:22px}
.h-head .grad{background:var(--accent-g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
#typed{color:var(--accent)}
.typed-cursor{color:var(--accent);animation:blink .75s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.h-sub{font-size:1.1rem;color:var(--muted);max-width:460px;line-height:1.85;margin-bottom:38px}
.h-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:52px}
.h-divider{width:100%;height:1px;background:linear-gradient(90deg,var(--border-hi),transparent);margin-bottom:36px}
.h-stats{display:flex;gap:40px}
.hst .n{font-family:var(--f-head);font-size:1.9rem;font-weight:800;line-height:1;background:var(--accent-g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hst .l{font-size:.73rem;color:var(--faint);margin-top:4px;letter-spacing:.05em;font-weight:500}
.h-card{background:var(--bg-card);border:1px solid var(--border-hi);border-radius:var(--r2);padding:36px;box-shadow:0 0 60px rgba(0,0,0,.35),0 0 0 1px rgba(255,255,255,.04) inset;position:relative;overflow:hidden}
.h-card::before{content:'';position:absolute;inset:0;border-radius:var(--r2);background:linear-gradient(135deg,rgba(79,172,222,.05) 0%,transparent 55%);pointer-events:none}
.h-avatar{width:68px;height:68px;border-radius:50%;background:var(--accent-g);display:flex;align-items:center;justify-content:center;font-family:var(--f-head);font-size:1.7rem;font-weight:800;color:#fff;margin-bottom:18px}
.h-card-name{font-family:var(--f-head);font-size:1.25rem;font-weight:700;margin-bottom:4px}
.h-card-role{font-size:.8rem;color:var(--accent);font-weight:600;letter-spacing:.04em;margin-bottom:20px}
.h-badges{display:flex;gap:8px;flex-wrap:wrap}
.hb{padding:4px 12px;border-radius:100px;font-size:.7rem;font-weight:700;letter-spacing:.03em;border:1px solid}
.hb-b{background:rgba(79,172,222,.1);color:var(--accent);border-color:rgba(79,172,222,.25)}
.hb-g{background:rgba(52,211,153,.1);color:var(--green);border-color:rgba(52,211,153,.25)}
.hb-p{background:rgba(167,139,250,.1);color:#A78BFA;border-color:rgba(167,139,250,.25)}
.h-card-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:24px;padding-top:22px;border-top:1px solid var(--border)}
.hcg-item{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px;padding:14px;text-align:center}
.hcg-item .n{font-family:var(--f-head);font-size:1.35rem;font-weight:800;color:var(--text);line-height:1}
.hcg-item .l{font-size:.68rem;color:var(--faint);margin-top:4px;letter-spacing:.04em}

/* PORTFOLIO */
#portfolio{padding:112px 0 72px}
.port-intro{display:flex;align-items:flex-end;justify-content:space-between;padding:0 36px;max-width:1140px;margin:0 auto 16px}
.drag-hint{display:flex;align-items:center;gap:8px;font-size:.73rem;color:var(--faint);letter-spacing:.08em;font-weight:600;text-transform:uppercase}
.port-scroll{overflow-x:auto;overflow-y:visible;padding:12px 36px 48px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:thin;scrollbar-color:rgba(79,172,222,.3) transparent;cursor:grab}
.port-scroll:active{cursor:grabbing}
.port-scroll::-webkit-scrollbar{height:3px}
.port-scroll::-webkit-scrollbar-track{background:transparent}
.port-scroll::-webkit-scrollbar-thumb{background:rgba(79,172,222,.3);border-radius:3px}
.port-track{display:flex;gap:24px;width:max-content;align-items:stretch}
.pcard{width:350px;flex-shrink:0;scroll-snap-align:start;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;display:flex;flex-direction:column;transition:border-color .3s,transform .3s var(--ease),box-shadow .3s}
.pcard:hover{border-color:rgba(79,172,222,.25);transform:translateY(-6px);box-shadow:0 24px 60px rgba(0,0,0,.35)}
.pcard-prev{height:210px;position:relative;overflow:hidden;cursor:pointer;background:var(--bg)}
.pcard-prev img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;transition:transform .5s var(--ease),filter .35s;filter:brightness(.9) saturate(1.05)}
.pcard:hover .pcard-prev img{transform:scale(1.05);filter:brightness(.75) saturate(1.1)}
.pcard-overlay{position:absolute;inset:0;background:rgba(8,11,18,.8);display:flex;align-items:center;justify-content:center;gap:8px;font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--accent);opacity:0;transition:opacity .25s;z-index:3}
.pcard:hover .pcard-overlay{opacity:1}
.pcard-vc{position:absolute;top:12px;right:12px;z-index:4;background:rgba(0,0,0,.5);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.08);padding:4px 10px;border-radius:100px;font-size:.68rem;font-weight:700;color:var(--faint);display:flex;align-items:center;gap:5px}
.pcard-body{padding:24px;flex:1;display:flex;flex-direction:column}
.pcard-t{font-family:var(--f-head);font-size:1.08rem;font-weight:700;margin-bottom:8px}
.pcard-t a:hover{color:var(--accent)}
.pcard-d{font-size:.85rem;color:var(--muted);line-height:1.72;flex:1;margin-bottom:16px}
.tags{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px}
.tag{font-size:.67rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 10px;border-radius:100px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--faint)}
.pcard-foot{display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid var(--border)}
.btn-cs{font-size:.78rem;font-weight:700;color:var(--accent);background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:5px;padding:0;transition:gap .2s var(--ease)}
.btn-cs:hover{gap:9px}
.lnk-live{font-size:.78rem;color:var(--muted);display:flex;align-items:center;gap:5px;transition:color .2s}
.lnk-live:hover{color:var(--accent)}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-txt p{color:var(--muted);font-size:1.04rem;line-height:1.9;margin-bottom:20px}
.c-row{display:flex;flex-direction:column;gap:13px;margin-top:32px}
.ci{display:flex;align-items:center;gap:14px;font-size:.9rem;color:var(--muted)}
.ci-ic{width:38px;height:38px;border-radius:9px;flex-shrink:0;background:rgba(79,172,222,.07);border:1px solid rgba(79,172,222,.15);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:1rem}
.ci a{color:var(--accent);font-weight:500}
.ci a:hover{text-decoration:underline}
.ab-card{background:var(--bg-card);border:1px solid var(--border-hi);border-radius:var(--r2);padding:36px;position:relative;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.25)}
.ab-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(167,139,250,.04) 0%,transparent 55%);pointer-events:none;border-radius:var(--r2)}
.checklist{display:flex;flex-direction:column;gap:16px}
.cli{display:flex;gap:13px;align-items:flex-start;font-size:.92rem;color:var(--muted);line-height:1.65}
.cli-ic{width:20px;height:20px;border-radius:50%;flex-shrink:0;margin-top:2px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:.6rem;color:#000;font-weight:900}
.ab-badge{position:absolute;bottom:-18px;right:-18px;background:var(--accent);color:#000;padding:18px 22px;border-radius:var(--r);text-align:center;box-shadow:0 8px 28px rgba(79,172,222,.35)}
.ab-badge .n{font-family:var(--f-head);font-size:1.9rem;font-weight:800;line-height:1}
.ab-badge .l{font-size:.7rem;font-weight:700;margin-top:3px;opacity:.75}

/* SERVICES */
.srv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px}
.srv{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r2);padding:32px 28px;position:relative;overflow:hidden;transition:border-color .3s,transform .3s var(--ease),box-shadow .3s}
.srv::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:var(--accent-g);transform:scaleX(0);transform-origin:left;transition:transform .35s var(--ease)}
.srv:hover{border-color:rgba(79,172,222,.2);transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.3)}
.srv:hover::after{transform:scaleX(1)}
.srv-ic{width:50px;height:50px;border-radius:12px;background:rgba(79,172,222,.08);border:1px solid rgba(79,172,222,.14);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:20px}
.srv-num{position:absolute;top:22px;right:22px;font-family:var(--f-head);font-size:2.2rem;font-weight:800;color:rgba(255,255,255,.035);line-height:1}
.srv-t{font-family:var(--f-head);font-size:1.05rem;font-weight:700;margin-bottom:10px}
.srv-d{font-size:.88rem;color:var(--muted);line-height:1.75;margin-bottom:16px}
.srv-list{display:flex;flex-direction:column;gap:8px;margin-top:4px}
.srv-li{font-size:.82rem;color:var(--faint);display:flex;gap:8px;align-items:flex-start;line-height:1.5}
.srv-li::before{content:'→';color:var(--accent);font-weight:700;flex-shrink:0;font-size:.75rem;margin-top:1px}

/* PROCESS */
.process-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0}
.proc-step{padding:28px 24px;position:relative;border:1px solid var(--border);background:var(--bg-card);margin:-1px 0 0 -1px}
.proc-step:first-child{border-radius:var(--r2) 0 0 0}
.proc-step:last-child{border-radius:0 var(--r2) var(--r2) 0}
.proc-num{font-family:var(--f-head);font-size:2.8rem;font-weight:800;line-height:1;background:var(--accent-g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;opacity:.35;margin-bottom:12px}
.proc-t{font-family:var(--f-head);font-size:.95rem;font-weight:700;margin-bottom:8px}
.proc-d{font-size:.82rem;color:var(--faint);line-height:1.65}

/* SKILLS */
.sk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:14px}
.ski{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r);padding:22px 16px;text-align:center;position:relative;overflow:hidden;transition:border-color .3s,transform .3s var(--ease)}
.ski-top{position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent-g);transform:scaleX(0);transform-origin:left;transition:transform .3s var(--ease)}
.ski:hover{border-color:rgba(79,172,222,.22);transform:translateY(-3px)}
.ski:hover .ski-top{transform:scaleX(1)}
.ski-ic{font-size:1.8rem;margin-bottom:10px;line-height:1}
.ski-n{font-size:.82rem;font-weight:700;color:var(--text)}
.ski-s{font-size:.7rem;color:var(--faint);margin-top:3px}

/* TESTIMONIALS */
.tst-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
.tst{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r2);padding:32px;transition:border-color .3s,transform .3s var(--ease)}
.tst:hover{border-color:rgba(79,172,222,.18);transform:translateY(-3px)}
.tst-q{font-family:var(--f-head);font-size:4rem;line-height:.7;color:var(--accent);opacity:.15;margin-bottom:12px;display:block}
.tst-stars{color:var(--gold);font-size:.8rem;margin-bottom:10px;letter-spacing:2px}
.tst-txt{font-size:.92rem;line-height:1.85;color:var(--muted);font-style:italic;margin-bottom:24px}
.tst-auth{display:flex;align-items:center;gap:14px}
.tst-av{width:42px;height:42px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--f-head);font-weight:800;font-size:.9rem;color:#000}
.av1{background:linear-gradient(135deg,#4FACDE,#2D8FB8)}
.av2{background:linear-gradient(135deg,#34D399,#059669)}
.av3{background:linear-gradient(135deg,#A78BFA,#7C3AED)}
.av4{background:linear-gradient(135deg,#F59E0B,#D97706)}
.av5{background:linear-gradient(135deg,#EC4899,#BE185D)}
.av6{background:linear-gradient(135deg,#14B8A6,#0F766E)}
.av7{background:linear-gradient(135deg,#6366F1,#4338CA)}
.tst-n{font-weight:700;font-size:.88rem}
.tst-r{font-size:.74rem;color:var(--faint);margin-top:2px}
.rating-strip{display:flex;align-items:center;justify-content:center;gap:40px;flex-wrap:wrap;padding:28px 40px;background:var(--bg-raised);border:1px solid var(--border);border-radius:var(--r2);margin-bottom:48px}
.rs-item{text-align:center}
.rs-num{font-family:var(--f-head);font-size:1.7rem;font-weight:800;background:var(--accent-g);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.rs-lbl{font-size:.72rem;color:var(--faint);margin-top:4px;letter-spacing:.05em}
.rs-div{width:1px;height:36px;background:var(--border)}

/* CONTACT */
#contact{background:var(--bg-card);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.ct-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.ct-info .ssub{margin-bottom:36px}
.cm{display:flex;align-items:center;gap:16px;padding:16px 0;border-bottom:1px solid var(--border)}
